  function handleIndexNodeContextMenu(
    e: React.MouseEvent,
    connectionId: string,
    node: ExplorerNode
  ): void {
    e.preventDefault()
    e.stopPropagation()
    // node.id format: "db:{dbName}:tables:{schema}.{tableName}:indexes:{indexName}"
    const match = node.id.match(/^db:([^:]+):tables:([^.]+)\.(.+):indexes:(.+)$/)
    if (!match) return
    const [, databaseName, schema, tableName, indexName] = match
    setContextMenu({
      items: [
        {
          id: 'edit-index',
          label: t('explorer.manageIndexes.editContextMenuLabel'),
          icon: <ListOrdered size={13} />,
          onClick: () =>
            setManageIndexesDialog({
              connectionId,
              databaseName,
              schema,
              tableName,
              initialIndexName: indexName
            })
        },
        { id: 'sep-idx-ops', separator: true },
        ...(getConnectionCapabilities(connectionId).hasIndexRebuild ? [{
          id: 'rebuild-index',
          label: t('explorer.manageIndexes.rebuild'),
          icon: <ListOrdered size={13} />,
          onClick: () => {
            void window.api.database
              .rebuildIndex(connectionId, databaseName, indexName, schema, tableName)
              .then((result) => {
                if (result.status === 'error') {
                  console.error('Rebuild failed:', result.message)
                } else {
                  void window.api.database.invalidateCache(
                    connectionId,
                    `db:${databaseName}:tables:${schema}.${tableName}:indexes`
                  ).then(() => {
                    loadNodeChildren(
                      connectionId,
                      `db:${databaseName}:tables:${schema}.${tableName}:indexes`
                    )
                  })
                }
              })
          }
        }] : []),
        ...(getConnectionCapabilities(connectionId).hasIndexReorganize ? [{
          id: 'reorganize-index',
          label: t('explorer.manageIndexes.reorganize'),
          icon: <ListOrdered size={13} />,
          onClick: () => {
            void window.api.database
              .reorganizeIndex(connectionId, databaseName, indexName, schema, tableName)
              .then((result) => {
                if (result.status === 'error') {
                  console.error('Reorganize failed:', result.message)
                } else {
                  void window.api.database.invalidateCache(
                    connectionId,
                    `db:${databaseName}:tables:${schema}.${tableName}:indexes`
                  ).then(() => {
                    loadNodeChildren(
                      connectionId,
                      `db:${databaseName}:tables:${schema}.${tableName}:indexes`
                    )
                  })
                }
              })
          }
        }] : []),
        ...(getConnectionCapabilities(connectionId).hasIndexDisable ? [{
          id: 'disable-index',
          label: t('explorer.manageIndexes.disable'),
          icon: <ListOrdered size={13} />,
          onClick: () => {
            void window.api.database
              .disableIndex(connectionId, databaseName, indexName, schema, tableName)
              .then((result) => {
                if (result.status === 'error') {
                  console.error('Disable failed:', result.message)
                } else {
                  void window.api.database.invalidateCache(
                    connectionId,
                    `db:${databaseName}:tables:${schema}.${tableName}:indexes`
                  ).then(() => {
                    loadNodeChildren(
                      connectionId,
                      `db:${databaseName}:tables:${schema}.${tableName}:indexes`
                    )
                  })
                }
              })
          }
        }] : [])
      ],
      position: { x: e.clientX, y: e.clientY }
    })
  }

